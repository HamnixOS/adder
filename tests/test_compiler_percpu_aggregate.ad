# tests/test_compiler_percpu_aggregate.ad — fixture for the
# Percpu[Array]/Percpu[Struct] aggregate-access fix.
#
# Before the fix, indexing or member-accessing a Percpu aggregate
# global silently lowered to `leaq buf(%rip)` — dropping the per-CPU
# base in %gs, so the access landed in the master template area, not
# this CPU's slot. Scalar Percpu[T] already used %gs:offset correctly;
# this fixture exercises the aggregate path and the host-side .sh
# driver greps for the `%gs:` prefix on every aggregate access.

# Multiple Percpu globals so the indexed-access disp lands at a
# non-zero per-CPU byte offset — proves the fix doesn't always
# resolve to disp=0 by accident.
prefix_pad: Percpu[uint64]

# Indexed access over an aggregate array.
arr_u64: Percpu[Array[8, uint64]]
arr_u32: Percpu[Array[8, uint32]]
arr_u16: Percpu[Array[8, uint16]]
arr_u8:  Percpu[Array[8, uint8]]

# A small struct laid out at a Percpu slot for member-access testing.
class Counters:
    hits: uint64
    misses: uint32
    flag: uint8

stats: Percpu[Counters]

# ---- Array load / store -------------------------------------------------

def load_arr_u64(i: uint64) -> uint64:
    return arr_u64[i]

def store_arr_u64(i: uint64, v: uint64):
    arr_u64[i] = v

def load_arr_u32(i: uint64) -> uint32:
    return arr_u32[i]

def store_arr_u32(i: uint64, v: uint32):
    arr_u32[i] = v

def load_arr_u16(i: uint64) -> uint16:
    return arr_u16[i]

def store_arr_u16(i: uint64, v: uint16):
    arr_u16[i] = v

def load_arr_u8(i: uint64) -> uint8:
    return arr_u8[i]

def store_arr_u8(i: uint64, v: uint8):
    arr_u8[i] = v

# ---- Struct field load / store ------------------------------------------

def load_hits() -> uint64:
    return stats.hits

def store_hits(v: uint64):
    stats.hits = v

def load_misses() -> uint32:
    return stats.misses

def store_misses(v: uint32):
    stats.misses = v

def load_flag() -> uint8:
    return stats.flag

def store_flag(v: uint8):
    stats.flag = v
