# tests/test_compiler_ptr_arith_scaled.ad — fixture for the
# `Ptr[T] + N` element-scaling fix.
#
# This file is the SOURCE that the host-side asm-shape test
# (scripts/test_compiler_ptr_arith_scaled.sh) compiles with
# `compiler.adder asm` and greps for the shift-scale instructions
# proving that `ptr + N` now lowers to `addq (N * sizeof(T))`, not a
# plain `addq N` byte add.
#
# We don't try to RUN this — the standalone adder repo has no Linux
# userland target — but every case below is also a positive sanity
# check that the compiler still accepts the code shape.

# Case 1: Ptr[uint64] + N must scale by 8 (shlq $3).
def case_u64_scaled(p: Ptr[uint64], n: uint64) -> Ptr[uint64]:
    return p + n

# Case 2: Ptr[uint32] + N must scale by 4 (shlq $2).
def case_u32_scaled(p: Ptr[uint32], n: uint64) -> Ptr[uint32]:
    return p + n

# Case 3: Ptr[uint16] + N must scale by 2 (shlq $1).
def case_u16_scaled(p: Ptr[uint16], n: uint64) -> Ptr[uint16]:
    return p + n

# Case 4: Ptr[uint8] + N must NOT scale — byte arithmetic preserved.
# This is the kernel's `cast[Ptr[uint8]](raw + offset)` idiom.
def case_u8_unscaled(p: Ptr[uint8], n: uint64) -> Ptr[uint8]:
    return p + n

# Case 5: Ptr[T] - N must also scale (matches C semantics).
def case_u64_sub_scaled(p: Ptr[uint64], n: uint64) -> Ptr[uint64]:
    return p - n

# Case 6: uint64 + uint64 (integer arithmetic, no pointer) must NOT
# scale. The kernel uses `cast[Ptr[T]](raw_u64 + byte_offset)` heavily
# (linux_abi/api_e1000e.ad, linux_abi/api_pci.ad).
def case_int_no_scale(raw: uint64, off: uint64) -> uint64:
    return raw + off

# Case 7: Ptr[T] - Ptr[T] must NOT scale: byte difference is the
# natural lowering (the compiler doesn't know whether the caller wants
# elements or bytes; existing kernel callers all want bytes).
def case_ptr_diff_unscaled(a: Ptr[uint64], b: Ptr[uint64]) -> uint64:
    return cast[uint64](a) - cast[uint64](b)
