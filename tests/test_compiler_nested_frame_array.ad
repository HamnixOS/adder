# tests/test_compiler_nested_frame_array.ad
#
# Compiler regression for the U9 nested-frame Array spill pattern (see
# memory/feedback_compiler_quirks.md "Nested fixed-size Array locals
# across call frames"). The canonical pattern, per the memory note, is
#
#   def caller(): local: Array[256, uint8]; callee(&local[0])
#
# where `callee` also declares a same-shape `Array[256, uint8]` local.
# The kernel-side surface (resolve_path inside `_u_openat`) showed
# byte-pointer args getting clobbered across the call boundary; the
# production fix is to inline the callee's body (see `_u_openat` in
# `linux_abi/u_syscalls.ad`).
#
# RESOLUTION (2026-05-20): the U9 nested-frame-Array bug is FIXED.
# The M16.134-era failure (`_u_openat` calling `_u_open` got -ENOENT)
# was a downstream symptom of two codegen defects that have since
# been fixed independently:
#   * 224051b — `&arr[i][j]` address-of on a 2-D Array miscompiled to
#     a dereference (NULL base);
#   * 18534b2 — sub-8-byte scalar locals stored/loaded with full
#     `movq`, leaving stale upper bytes after a sized `Ptr[T]` write.
# Both were the actual frame-layout / spill interactions the U9 note
# guessed at. With them fixed, the cross-frame Array pattern works.
# Verified 2026-05-20 by reverting the `_u_openat` inline workaround
# to a plain `_u_open()` call: scripts/test_u9_access.sh still PASSes
# the openat marker.
#
# This fixture is PASS-expected and now guards TWO shapes so a future
# codegen regression is caught at the compiler-suite level:
#   1. caller_top -> middle_callee -> callee_deep — three same-shape
#      Array[256] frames, pointer threaded through each (the original
#      abstract pattern).
#   2. The writer/reader cross-frame shape that mirrors the real
#      _u_open kernel path: a caller declares Array[256] `abs_path`,
#      hands &abs_path[0] to a WRITER frame (own Array[256]+Array[64],
#      recurses into a normaliser frame that also owns Array[256]) that
#      fills the buffer through the pointer, then hands the SAME
#      pointer to a READER frame (own Array[256]+Array[64]) that reads
#      it back. This is the exact resolve_path-writes / vfs_open-reads
#      ingredient set the M16.134 note blamed.
#
# Repro shape 1 (mirrors the resolve_path / _u_openat call chain):
#   caller_top -> middle_callee -> callee_deep
# Each frame declares a same-shape Array[256, uint8] + an
# Array[64, uint8] aux scratch; each intermediate frame re-checks the
# byte pattern through the passed pointer.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: int32)


def _check_pattern(buf: Ptr[uint8], n: uint64) -> int32:
    i: uint64 = 0
    while i < n:
        expected: uint8 = cast[uint8](i & 0xFF)
        if buf[i] != expected:
            return 1
        i = i + 1
    return 0


def callee_deep(in_buf: Ptr[uint8]) -> int32:
    # Depth-2 callee. Same-shape Array locals as caller_top and
    # middle_callee to maximize the spill collision pressure.
    deep_scratch: Array[256, uint8]
    deep_aux: Array[64, uint8]
    i: uint64 = 0
    while i < 256:
        deep_scratch[i] = 0
        i = i + 1
    j: uint64 = 0
    while j < 64:
        deep_aux[j] = 0
        j = j + 1
    return _check_pattern(in_buf, 256)


def middle_callee(in_buf: Ptr[uint8]) -> int32:
    # Depth-1 callee. Same-shape Array locals; passes pointer onward.
    mid_scratch: Array[256, uint8]
    mid_aux: Array[64, uint8]
    i: uint64 = 0
    while i < 256:
        mid_scratch[i] = 0
        i = i + 1
    j: uint64 = 0
    while j < 64:
        mid_aux[j] = 0
        j = j + 1

    # First check the buffer at this depth.
    rc1: int32 = _check_pattern(in_buf, 256)
    if rc1 != 0:
        return rc1
    # Then recurse: passes byte pointer derived from caller's Array
    # through a same-shape-Array frame, the exact U9 ingredient.
    return callee_deep(in_buf)


def caller_top() -> int32:
    local: Array[256, uint8]
    aux: Array[64, uint8]
    k: uint64 = 0
    while k < 256:
        local[k] = cast[uint8](k & 0xFF)
        k = k + 1
    m: uint64 = 0
    while m < 64:
        aux[m] = 0
        m = m + 1
    return middle_callee(&local[0])


# --- Shape 2: writer/reader cross-frame (mirrors _u_open) -------------
# A normaliser frame that ALSO declares Array[256, uint8] — the third
# same-shape frame in the writer's call chain, like resolve_path
# recursing into _resolve_path_canonical-shaped helpers.
def u9_normalise(p: Ptr[uint8], n: uint64) -> int32:
    norm_scratch: Array[256, uint8]
    i: uint64 = 0
    while i < 256:
        norm_scratch[i] = cast[uint8]((i * 7) & 0xFF)
        i = i + 1
    sum: uint64 = 0
    j: uint64 = 0
    while j < n:
        sum = sum + cast[uint64](p[j])
        j = j + 1
    if sum == 0xFFFFFFFFFFFFFFFF:
        return 1
    return 0


# Writer frame: two same-shape Array locals (like resolve_path's
# scratch), fills the caller's buffer THROUGH the passed pointer, then
# recurses into a third same-shape frame.
def u9_writer(dst: Ptr[uint8], cap: uint64) -> int32:
    w_scratch: Array[256, uint8]
    w_aux: Array[64, uint8]
    i: uint64 = 0
    while i < 256:
        w_scratch[i] = 0
        i = i + 1
    j: uint64 = 0
    while j < 64:
        w_aux[j] = 0
        j = j + 1
    k: uint64 = 0
    while k < cap:
        dst[k] = cast[uint8](k & 0xFF)
        k = k + 1
    return u9_normalise(dst, cap)


# Reader frame: same-shape Array locals; reads the caller's buffer
# back through the pointer and verifies the writer's pattern.
def u9_reader(in_buf: Ptr[uint8], n: uint64) -> int32:
    r_scratch: Array[256, uint8]
    r_aux: Array[64, uint8]
    i: uint64 = 0
    while i < 256:
        r_scratch[i] = 0
        i = i + 1
    j: uint64 = 0
    while j < 64:
        r_aux[j] = 0
        j = j + 1
    m: uint64 = 0
    while m < n:
        expect: uint8 = cast[uint8](m & 0xFF)
        if in_buf[m] != expect:
            return 1
        m = m + 1
    return 0


def u9_writer_reader() -> int32:
    abs_path: Array[256, uint8]
    aux: Array[64, uint8]
    z: uint64 = 0
    while z < 64:
        aux[z] = 0
        z = z + 1
    wrc: int32 = u9_writer(&abs_path[0], 256)
    if wrc != 0:
        return wrc
    return u9_reader(&abs_path[0], 256)


pass_msg: Array[32, uint8]


def main():
    rc: int32 = caller_top()
    if rc == 0:
        rc = u9_writer_reader()
    if rc == 0:
        pass_msg[0]  = 91   # '['
        pass_msg[1]  = 110  # 'n'
        pass_msg[2]  = 101  # 'e'
        pass_msg[3]  = 115  # 's'
        pass_msg[4]  = 116  # 't'
        pass_msg[5]  = 101  # 'e'
        pass_msg[6]  = 100  # 'd'
        pass_msg[7]  = 95   # '_'
        pass_msg[8]  = 102  # 'f'
        pass_msg[9]  = 114  # 'r'
        pass_msg[10] = 97   # 'a'
        pass_msg[11] = 109  # 'm'
        pass_msg[12] = 101  # 'e'
        pass_msg[13] = 95   # '_'
        pass_msg[14] = 97   # 'a'
        pass_msg[15] = 114  # 'r'
        pass_msg[16] = 114  # 'r'
        pass_msg[17] = 97   # 'a'
        pass_msg[18] = 121  # 'y'
        pass_msg[19] = 93   # ']'
        pass_msg[20] = 32   # ' '
        pass_msg[21] = 80   # 'P'
        pass_msg[22] = 65   # 'A'
        pass_msg[23] = 83   # 'S'
        pass_msg[24] = 83   # 'S'
        pass_msg[25] = 10   # '\n'
        sys_write(1, &pass_msg[0], 26)
    sys_exit(rc)
