# Compiler regression: &arr[i][j] on 2-D Array global used to miscompile
# to NULL because gen_index_address dereferenced the inner IndexExpr
# instead of taking its address. Fix (2026-05-18) in
# compiler/codegen_x86.py: gen_index_address uses gen_addr_of when the
# base's static type is ArrayType.
#
# This fixture exits 0 + emits a PASS marker iff the fix is in place.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: int32)

arr2d:    Array[4, Array[6, uint8]]
pass_msg: Array[24, uint8]


def main():
    arr2d[1][3] = 99
    p: Ptr[uint8] = &arr2d[1][3]
    rc: int32 = 0
    if cast[uint64](p) == 0:
        rc = 1
    elif p[0] != 99:
        rc = 2
    if rc == 0:
        pass_msg[0]  = 91  # '['
        pass_msg[1]  = 99  # 'c'
        pass_msg[2]  = 111 # 'o'
        pass_msg[3]  = 109 # 'm'
        pass_msg[4]  = 112 # 'p'
        pass_msg[5]  = 95  # '_'
        pass_msg[6]  = 110 # 'n'
        pass_msg[7]  = 101 # 'e'
        pass_msg[8]  = 115 # 's'
        pass_msg[9]  = 116 # 't'
        pass_msg[10] = 93  # ']'
        pass_msg[11] = 32  # ' '
        pass_msg[12] = 80  # 'P'
        pass_msg[13] = 65  # 'A'
        pass_msg[14] = 83  # 'S'
        pass_msg[15] = 83  # 'S'
        pass_msg[16] = 10  # '\n'
        sys_write(1, &pass_msg[0], 17)
    sys_exit(rc)
