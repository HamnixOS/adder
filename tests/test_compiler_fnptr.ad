# tests/test_compiler_fnptr.ad
#
# Compiler regression: first-class function pointers (`Fn[R, A...]`).
#
# Adder gained a real first-class function-pointer type. A function
# name used as a value yields a `Fn[...]` value; a value of that type
# is callable with ordinary call syntax. The SysV-AMD64 indirect-call
# codegen marshals arguments into rdi/rsi/rdx/rcx/r8/r9 (+ stack for
# the rest) and calls through the register operand — the same
# argument-setup path a direct call uses, differing only in the final
# `call *` operand.
#
# Before this, indirect calls were an `asm_volatile("call *%rax")`-
# shaped hack (or a `cast[Ptr[uint8]]` + local-binding trick): the
# kernel's IRQ dispatch table, the block-device vtable, the netfilter
# hook chain, and the timer/hrtimer/kthread dispatchers all routed
# through it. With the real type those become ordinary calls.
#
# This fixture exercises every storage class a `devtab`-style dispatch
# table needs:
#   1. A function pointer in a LOCAL, called.
#   2. A function pointer in a GLOBAL, called.
#   3. A function pointer in a STRUCT FIELD, called.
#   4. An ARRAY of function pointers (a dispatch table), indexed+called.
#   5. A function pointer passed as an ARGUMENT, called by the callee.
#   6. An indirect call with SEVEN arguments (rdi..r9 + one on the
#      stack) returning a value — proves the stack-arg marshaling path
#      composes with the indirect `call *`.
#
# Driven by scripts/test_compiler_fnptr.sh: builds this .ad as a
# userland x86_64 ELF, plants it as /init, boots QEMU, greps the
# serial log for the [fnptr] PASS banner. Same shape as
# scripts/test_compiler_string_global.sh.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: int32)


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def emit(msg: Ptr[uint8]):
    sys_write(1, msg, strlen(msg))


def fail(msg: Ptr[uint8]):
    emit("[fnptr] FAIL ")
    emit(msg)
    emit("\n")
    sys_exit(1)


# --- callees the fixture takes the address of -------------------------

def add(a: int64, b: int64) -> int64:
    return a + b


def mul(a: int64, b: int64) -> int64:
    return a * b


def sub(a: int64, b: int64) -> int64:
    return a - b


# Seven-argument callee: args 0..5 arrive in rdi/rsi/rdx/rcx/r8/r9,
# arg 6 on the stack. Returns a value that depends on all seven.
def sum7(a: int64, b: int64, c: int64, d: int64,
         e: int64, f: int64, g: int64) -> int64:
    return a + b + c + d + e + f + g


# --- storage classes --------------------------------------------------

# Case 2: function pointer in a GLOBAL. The global is assigned at
# runtime in main(). (A static `= add` initialiser emits a `.quad add`
# 64-bit absolute relocation — valid on the elf64 kernel target, but
# the userland ELF here is wrapped as elf32-i386 which has no 8-byte
# relocation, so a static function-pointer-global initialiser is a
# kernel-target-only feature. Runtime assignment works on both.)
g_op: Fn[int64, int64, int64]


# Case 3: a struct whose field is a function pointer.
class Dispatcher:
    op: Fn[int64, int64, int64]
    tag: int64


# Case 4: an array of function pointers — a dispatch table.
devtab: Array[3, Fn[int64, int64, int64]]


# --- Case 5: function pointer passed as an argument -------------------

def apply2(fn: Fn[int64, int64, int64], x: int64, y: int64) -> int64:
    return fn(x, y)


def main():
    emit("[fnptr] start\n")

    # Case 1: function pointer in a LOCAL.
    local_op: Fn[int64, int64, int64] = mul
    if local_op(6, 7) != 42:
        fail("case_local: mul(6,7) != 42")
    local_op = sub
    if local_op(100, 58) != 42:
        fail("case_local: sub(100,58) != 42")
    emit("[fnptr] case_local OK\n")

    # Case 2: function pointer in a GLOBAL — stored, loaded, called.
    g_op = add
    if g_op(40, 2) != 42:
        fail("case_global: g_op(40,2) != 42")
    g_op = mul
    if g_op(21, 2) != 42:
        fail("case_global: g_op(21,2) != 42 after reassign")
    emit("[fnptr] case_global OK\n")

    # Case 3: function pointer in a STRUCT FIELD.
    d: Dispatcher
    d.op = add
    d.tag = 7
    fn_from_field: Fn[int64, int64, int64] = d.op
    if fn_from_field(35, 7) != 42:
        fail("case_struct: d.op(35,7) != 42")
    if d.tag != 7:
        fail("case_struct: tag clobbered")
    emit("[fnptr] case_struct OK\n")

    # Case 4: an ARRAY of function pointers — a dispatch table.
    devtab[0] = add
    devtab[1] = mul
    devtab[2] = sub
    sel0: Fn[int64, int64, int64] = devtab[0]
    sel1: Fn[int64, int64, int64] = devtab[1]
    sel2: Fn[int64, int64, int64] = devtab[2]
    if sel0(20, 22) != 42:
        fail("case_array: devtab[0](20,22) != 42")
    if sel1(7, 6) != 42:
        fail("case_array: devtab[1](7,6) != 42")
    if sel2(50, 8) != 42:
        fail("case_array: devtab[2](50,8) != 42")
    emit("[fnptr] case_array OK\n")

    # Case 5: function pointer passed as an ARGUMENT.
    if apply2(add, 19, 23) != 42:
        fail("case_arg: apply2(add,19,23) != 42")
    if apply2(mul, 2, 21) != 42:
        fail("case_arg: apply2(mul,2,21) != 42")
    emit("[fnptr] case_arg OK\n")

    # Case 6: a SEVEN-argument indirect call with a return value.
    # 1+2+3+4+5+6+21 == 42; arg 6 (the 21) travels on the stack.
    seven: Fn[int64, int64, int64, int64, int64, int64, int64, int64] = sum7
    if seven(1, 2, 3, 4, 5, 6, 21) != 42:
        fail("case_seven_args: sum7(1..6,21) != 42")
    emit("[fnptr] case_seven_args OK\n")

    emit("[fnptr] PASS\n")
    sys_exit(0)
