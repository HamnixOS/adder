# Compiler regression: nested class-instance fields appear to alias.
#
# The V2 RSA-PSS agent (commit 3c4f152) hit this writing
# `class RsaPubkey { modulus: Bigint, exponent: Bigint }` — writes to
# the exponent's limbs aliased into the modulus's tail. The agent
# worked around it by holding raw byte buffers in RsaPubkey + putting
# the live bigints in module-scope scratch.
#
# This fixture is a minimal repro. Two `Inner` instances inside one
# `Outer`. We write distinct sentinel values into each Inner's array
# and assert they don't aliase.
#
# Marker: [nested_class] PASS on success.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: int32)


class Inner:
    data: Array[8, uint64]


class Outer:
    a: Inner
    b: Inner


outer: Outer
pass_msg: Array[24, uint8]
fail_msg: Array[24, uint8]


def _set_pass():
    pass_msg[0]  = 91   # '['
    pass_msg[1]  = 110  # 'n'
    pass_msg[2]  = 101  # 'e'
    pass_msg[3]  = 115  # 's'
    pass_msg[4]  = 116  # 't'
    pass_msg[5]  = 101  # 'e'
    pass_msg[6]  = 100  # 'd'
    pass_msg[7]  = 95   # '_'
    pass_msg[8]  = 99   # 'c'
    pass_msg[9]  = 108  # 'l'
    pass_msg[10] = 97   # 'a'
    pass_msg[11] = 115  # 's'
    pass_msg[12] = 115  # 's'
    pass_msg[13] = 93   # ']'
    pass_msg[14] = 32   # ' '
    pass_msg[15] = 80   # 'P'
    pass_msg[16] = 65   # 'A'
    pass_msg[17] = 83   # 'S'
    pass_msg[18] = 83   # 'S'
    pass_msg[19] = 10   # '\n'


def _set_fail():
    fail_msg[0]  = 91
    fail_msg[1]  = 110
    fail_msg[2]  = 101
    fail_msg[3]  = 115
    fail_msg[4]  = 116
    fail_msg[5]  = 101
    fail_msg[6]  = 100
    fail_msg[7]  = 95
    fail_msg[8]  = 99
    fail_msg[9]  = 108
    fail_msg[10] = 97
    fail_msg[11] = 115
    fail_msg[12] = 115
    fail_msg[13] = 93
    fail_msg[14] = 32
    fail_msg[15] = 70   # 'F'
    fail_msg[16] = 65
    fail_msg[17] = 73   # 'I'
    fail_msg[18] = 76   # 'L'
    fail_msg[19] = 10


def main():
    _set_pass()
    _set_fail()

    # Write a recognisable pattern into each Inner.
    i: uint64 = 0
    while i < 8:
        outer.a.data[i] = 0xAAAA_0000_0000_0000 | i
        outer.b.data[i] = 0xBBBB_0000_0000_0000 | i
        i = i + 1

    # Read back — outer.a.data MUST still be the AAAA pattern.
    rc: int32 = 0
    j: uint64 = 0
    while j < 8:
        expected_a: uint64 = 0xAAAA_0000_0000_0000 | j
        expected_b: uint64 = 0xBBBB_0000_0000_0000 | j
        if outer.a.data[j] != expected_a:
            rc = 1
        if outer.b.data[j] != expected_b:
            rc = 2
        j = j + 1

    if rc == 0:
        sys_write(1, &pass_msg[0], 20)
        sys_exit(0)
    sys_write(1, &fail_msg[0], 20)
    sys_exit(rc)
