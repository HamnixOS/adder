# tests/test_compiler_module_private.ad — compiler regression for
# per-module symbol scoping (module-private leading-underscore names).
#
# THE BUG (fixed by the module-resolution pass in compiler/adder.py):
# merge_programs() flattened every module's top-level declarations
# into ONE Program keyed by a single global `seen_names` dict, so two
# .ad files each defining a private helper of the same natural name
# (e.g. `_scale`, `_emit_str`) was a HARD ERROR. Developers had to
# rename helpers per-file (`_ci_emit_str`, `_mi_emit_str`, ...).
#
# THE FIX: a leading-underscore top-level name is module-private and
# is mangled per-module to `<module>__<name>`; intra-module references
# (calls, identifier loads, `&fn`) are rewritten to match. Non-
# underscore names stay globally visible. A name explicitly `import`ed
# by another module is promoted back to public (the import IS the
# export annotation).
#
# This fixture exercises THREE modules each defining a private
# `_scale`:
#   * tests/modpriv_a.ad   — `_scale(x) = x * 10`,  public `mp_a`
#   * tests/modpriv_b.ad   — `_scale(x) = x + 100`, public `mp_b`
#   * this file            — `_scale(x) = x - 1`
# Before the fix this would not compile at all. With the fix all
# three coexist, and each module's `_scale` resolves to its own body.
#
# PASS criterion: `[modpriv] PASS` in the serial log, which only
# prints iff:   mp_a(5) == 50  AND  mp_b(5) == 105  AND  _scale(5) == 4
# (i.e. the fixture's own private `_scale` was NOT shadowed by A's or
# B's, and the call sites in A and B resolved to their own helpers).

from tests.modpriv_a import mp_a
from tests.modpriv_b import mp_b

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: int32)

pass_msg: Array[24, uint8]


# This module's OWN private `_scale` — third same-named private helper.
def _scale(x: int32) -> int32:
    return x - 1


def main():
    rc: int32 = 0

    # A's _scale: 5 * 10 == 50
    if mp_a(5) != 50:
        rc = 1
    # B's _scale: 5 + 100 == 105
    elif mp_b(5) != 105:
        rc = 2
    # This module's own _scale: 5 - 1 == 4
    elif _scale(5) != 4:
        rc = 3

    if rc == 0:
        pass_msg[0]  = 91   # '['
        pass_msg[1]  = 109  # 'm'
        pass_msg[2]  = 111  # 'o'
        pass_msg[3]  = 100  # 'd'
        pass_msg[4]  = 112  # 'p'
        pass_msg[5]  = 114  # 'r'
        pass_msg[6]  = 105  # 'i'
        pass_msg[7]  = 118  # 'v'
        pass_msg[8]  = 93   # ']'
        pass_msg[9]  = 32   # ' '
        pass_msg[10] = 80   # 'P'
        pass_msg[11] = 65   # 'A'
        pass_msg[12] = 83   # 'S'
        pass_msg[13] = 83   # 'S'
        pass_msg[14] = 10   # '\n'
        sys_write(1, &pass_msg[0], 15)
    sys_exit(rc)
