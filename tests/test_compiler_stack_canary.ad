# tests/test_compiler_stack_canary.ad
#
# Compiler regression: stack-canary V0. The codegen
# (compiler/codegen_x86.py) emits a `-fstack-protector-strong`-shaped
# prologue/epilogue at every function tagged `needs_canary`:
#   * any function with an Array[N, T] local where N >= 8, OR
#   * any function that takes `&local`.
# The prologue stashes __stack_chk_guard at -8(%rbp); the epilogue
# XORs the slot with the guard and tail-calls __stack_chk_fail on
# mismatch. The user-side __stack_chk_fail (user/runtime.S) sys_exit's
# with code 134 (Linux's SIGABRT exit code, what glibc's stack-
# protector runtime uses) — distinct enough from any normal exit
# code to be unambiguous in the serial log.
#
# This fixture covers two paths:
#
#   Path A — BENIGN (must PASS):
#     A function with Array[16, uint8] writes arr[0..15] in-bounds,
#     emits "[canary] benign PASS", returns. The codegen ADDS a
#     canary to this function (16 >= 8); the epilogue must pass
#     because no overrun occurred. If the test framework saw
#     [canary] benign PASS, the canary instrumentation is
#     transparent — it doesn't break working code.
#
#   Path B — DETECTION (must trip):
#     The same shape of function, but writes arr[20] = 0xFF. With
#     the canary slot at -8(%rbp) and Array[16, uint8] sitting at
#     -24..-9, arr[20] addresses -24+20 = -4, which lives inside
#     the canary slot. The return-time canary check sees a
#     mismatch and tail-call's __stack_chk_fail → sys_exit(134).
#     Path B's function does NOT return to its caller, so we
#     emit the "[canary] about to overrun" marker BEFORE the
#     call. The test wrapper then `echo $?` to see 134 in the
#     hamsh log.
#
# Driven by scripts/test_compiler_stack_canary.sh: builds this .ad
# as a userland x86_64 ELF, plants it at /bin/test_compiler_stack_
# canary in the cpio initramfs, boots QEMU + hamsh, runs the binary
# + `echo $?`, then asserts on the serial log for the expected
# markers and exit code. Same shape as scripts/test_compiler_ptr_
# local.sh.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: uint64)


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def emit(msg: Ptr[uint8]):
    sys_write(1, msg, strlen(msg))


# ----------------------------------------------------------------------
# Path A: BENIGN. Function with a canary-triggering local that stays
# strictly in-bounds. After the codegen change, this function has a
# canary slot at -8(%rbp) and the array at -24..-9; the write loop
# touches only those bytes, so the epilogue check passes cleanly and
# we get a normal return.

def path_a_benign() -> int32:
    arr: Array[16, uint8]
    i: int32 = 0
    while i < 16:
        arr[i] = cast[uint8](i)
        i = i + 1
    # Sum the bytes back so the writes can't be optimised away (the
    # current codegen doesn't have a dead-store eliminator, but
    # being explicit costs nothing and futureproofs the fixture).
    sum: int32 = 0
    i = 0
    while i < 16:
        sum = sum + cast[int32](arr[i])
        i = i + 1
    return sum


# ----------------------------------------------------------------------
# Path B: DETECTION. Same shape as path_a but writes one byte past
# the canary slot. arr's layout under the canary-aware codegen:
#   -8 .. -1  : canary slot (8 bytes)
#   -24 .. -9 : arr[0..15]
# Writing arr[20] addresses -24 + 20 = -4, smack inside the canary
# slot. On return the epilogue's XOR-then-test sees a mismatch and
# jumps to __stack_chk_fail, which sys_exit(134)s — control does
# NOT return to the caller.

def path_b_overrun() -> int32:
    arr: Array[16, uint8]
    i: int32 = 0
    while i < 16:
        arr[i] = 0
        i = i + 1
    # The actual overrun. 0xFF was picked because it has good
    # Hamming distance from the canary's leading byte (0xC0 from
    # 0xC0FFEEDEADBEEFC0), guaranteeing the post-XOR result is
    # non-zero regardless of which canary byte we land on.
    arr[20] = 0xFF
    # Returning is the load-bearing action — the codegen-emitted
    # epilogue runs the canary check ONLY on the way out.
    return 0


def main() -> int32:
    emit("[canary] start\n")

    # Benign path — must round-trip and reach the marker.
    rc_a: int32 = path_a_benign()
    if rc_a != 120:
        # sum(0..15) = 120. If the canary instrumentation broke
        # the body, this is where we'd see it.
        emit("[canary] FAIL benign: bad checksum\n")
        sys_exit(1)
    emit("[canary] benign PASS\n")

    # Detection path — must not return.
    emit("[canary] about to overrun\n")
    path_b_overrun()

    # Should be unreachable. If we get here the canary check FAILED
    # to detect the overrun — print a recognisable line so the test
    # wrapper can flag it.
    emit("[canary] FAIL: path_b returned (canary check did not fire)\n")
    sys_exit(2)
