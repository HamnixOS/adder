# tests/test_compiler_unsigned_divshift.ad
#
# Compiler regression: the x86_64 backend must honour operand
# SIGNEDNESS when lowering `>>`, `/`, `//` and `%`.
#
# x86 carries signedness in the instruction, not the data:
#   right shift:  sarq (signed, sign-extends) vs shrq (unsigned, zero-fill)
#   division:     idivq (signed, cqo-extended) vs divq (unsigned, %rdx=0)
#
# Historically gen_binary() in compiler/codegen_x86.py emitted ONLY the
# unsigned forms (shrq / divq) for `>>`, `/` and `%`, with a comment
# claiming "Adder ints are non-negative". That miscompiles signed
# arithmetic. The earlier comparison fix (commit a5a7e55) added
# `_is_unsigned_type`; this fixture is the regression guard for the
# matching shift + divide fix (`_binop_signed_op`).
#
# Tested:
#   1. Unsigned `>>` on a value with the high bit set MUST zero-fill
#      (shrq) — 0xFFFFFFFFFFFFFFF0 >> 4 == 0x0FFFFFFFFFFFFFFF, NOT
#      0xFFFFFFFFFFFFFFFF.
#   2. Unsigned `/` MUST be divq — 0xFFFFFFFFFFFFFFFF / 2 ==
#      0x7FFFFFFFFFFFFFFF (idivq would trap / give a wrong quotient on
#      a dividend that is "negative" when read as signed).
#   3. Unsigned `%` MUST be divq — 0xFFFFFFFFFFFFFFFF % 10 == 5.
#   4. Signed `>>` on a negative int64 MUST sign-extend (sarq) —
#      (-16) >> 2 == -4.
#   5. Signed `/` on a negative int64 MUST be idivq — (-100) / 7 == -14
#      (truncates toward zero).
#   6. Signed `%` on a negative int64 MUST be idivq — (-100) % 7 == -2.
#
# Driven by scripts/test_compiler_unsigned_divshift.sh: builds this as a
# userland ELF, plants it as /init, boots QEMU, greps the serial log for
# `[unsigned_divshift] PASS`.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: int32)

fail_msg: Array[32, uint8]
pass_msg: Array[32, uint8]


def emit_fail(code: int32):
    fail_msg[0]  = 91   # '['
    fail_msg[1]  = 117  # 'u'
    fail_msg[2]  = 110  # 'n'
    fail_msg[3]  = 115  # 's'
    fail_msg[4]  = 105  # 'i'
    fail_msg[5]  = 103  # 'g'
    fail_msg[6]  = 110  # 'n'
    fail_msg[7]  = 101  # 'e'
    fail_msg[8]  = 100  # 'd'
    fail_msg[9]  = 95   # '_'
    fail_msg[10] = 100  # 'd'
    fail_msg[11] = 105  # 'i'
    fail_msg[12] = 118  # 'v'
    fail_msg[13] = 115  # 's'
    fail_msg[14] = 104  # 'h'
    fail_msg[15] = 105  # 'i'
    fail_msg[16] = 102  # 'f'
    fail_msg[17] = 116  # 't'
    fail_msg[18] = 93   # ']'
    fail_msg[19] = 32   # ' '
    fail_msg[20] = 70   # 'F'
    fail_msg[21] = 65   # 'A'
    fail_msg[22] = 73   # 'I'
    fail_msg[23] = 76   # 'L'
    fail_msg[24] = 10   # '\n'
    sys_write(1, &fail_msg[0], 25)
    sys_exit(code)


def main():
    # --- Case 1: unsigned right shift, high bit set -> logical (shrq) ---
    u1: uint64 = 0xFFFFFFFFFFFFFFF0
    s1: uint64 = u1 >> 4
    if s1 != 0x0FFFFFFFFFFFFFFF:
        emit_fail(1)

    # A shift count of 1 on the all-ones value: 0x7FFF...FFFF, not -1.
    u1b: uint64 = 0xFFFFFFFFFFFFFFFF
    if (u1b >> 1) != 0x7FFFFFFFFFFFFFFF:
        emit_fail(2)

    # --- Case 2: unsigned divide -> divq ---
    u2: uint64 = 0xFFFFFFFFFFFFFFFF
    q2: uint64 = u2 / 2
    if q2 != 0x7FFFFFFFFFFFFFFF:
        emit_fail(3)

    # Divisor that exposes the full unsigned range: (2^64-1)/3.
    if (u2 / 3) != 0x5555555555555555:
        emit_fail(4)

    # --- Case 3: unsigned modulo -> divq ---
    # 18446744073709551615 % 10 == 5.
    u3: uint64 = 0xFFFFFFFFFFFFFFFF
    if (u3 % 10) != 5:
        emit_fail(5)

    # --- Case 4: signed right shift, negative -> arithmetic (sarq) ---
    n1: int64 = -16
    if (n1 >> 2) != -4:
        emit_fail(6)

    # -1 >> 3 stays -1 under arithmetic shift.
    n1b: int64 = -1
    if (n1b >> 3) != -1:
        emit_fail(7)

    # --- Case 5: signed divide -> idivq ---
    n2: int64 = -100
    if (n2 / 7) != -14:
        emit_fail(8)

    # Negative / negative -> positive quotient.
    n2b: int64 = -100
    d2b: int64 = -4
    if (n2b / d2b) != 25:
        emit_fail(9)

    # --- Case 6: signed modulo -> idivq ---
    # -100 % 7 == -2 (idivq truncates toward zero, remainder takes the
    # sign of the dividend).
    n3: int64 = -100
    if (n3 % 7) != -2:
        emit_fail(10)

    # --- Mixed signedness: unsigned operand wins (C-style) -> divq ---
    # If `uint64 / int_literal` ever picked idivq, the huge dividend
    # would read as negative and the quotient would be wrong.
    um: uint64 = 0xFFFFFFFFFFFFFFFE
    if (um / 2) != 0x7FFFFFFFFFFFFFFF:
        emit_fail(11)
    if (um >> 1) != 0x7FFFFFFFFFFFFFFF:
        emit_fail(12)

    pass_msg[0]  = 91   # '['
    pass_msg[1]  = 117  # 'u'
    pass_msg[2]  = 110  # 'n'
    pass_msg[3]  = 115  # 's'
    pass_msg[4]  = 105  # 'i'
    pass_msg[5]  = 103  # 'g'
    pass_msg[6]  = 110  # 'n'
    pass_msg[7]  = 101  # 'e'
    pass_msg[8]  = 100  # 'd'
    pass_msg[9]  = 95   # '_'
    pass_msg[10] = 100  # 'd'
    pass_msg[11] = 105  # 'i'
    pass_msg[12] = 118  # 'v'
    pass_msg[13] = 115  # 's'
    pass_msg[14] = 104  # 'h'
    pass_msg[15] = 105  # 'i'
    pass_msg[16] = 102  # 'f'
    pass_msg[17] = 116  # 't'
    pass_msg[18] = 93   # ']'
    pass_msg[19] = 32   # ' '
    pass_msg[20] = 80   # 'P'
    pass_msg[21] = 65   # 'A'
    pass_msg[22] = 83   # 'S'
    pass_msg[23] = 83   # 'S'
    pass_msg[24] = 10   # '\n'
    sys_write(1, &pass_msg[0], 25)
    sys_exit(0)
