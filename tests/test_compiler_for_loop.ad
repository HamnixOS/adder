# Compiler regression fixture: `for ... in` loops.
#
# Until this landed, the parser built a ForStmt node but the x86_64
# codegen rejected it with "x86: statement ForStmt not yet supported",
# so NOT A SINGLE .ad file in Hamnix used a for-loop — every loop was a
# hand-rolled `while` with an explicit counter. This fixture exercises
# the new lowering end to end: each function computes a value with a
# known answer, and the host-side driver (test_compiler_for_loop.sh)
# links these against a tiny C main and asserts the results.
#
# Covered shapes (LANGUAGE.md "Control Flow -> Loops"):
#   * for i in range(stop)
#   * for i in range(start, stop)
#   * for i in range(start, stop, step)   (ascending AND descending)
#   * for x in <fixed-size Array[N, T]>
#   * break / continue inside a for-loop (continue still advances)
#   * nested for-loops

# sum 0..9 == 45
def sum_to_ten() -> int32:
    s: int32 = 0
    for i in range(10):
        s = s + i
    return s

# sum 3..6 == 18  (range(start, stop) is half-open)
def sum_range_3_7() -> int32:
    t: int32 = 0
    for i in range(3, 7):
        t = t + i
    return t

# count of 0,2,4,6,8 == 5
def step_count() -> int32:
    c: int32 = 0
    for i in range(0, 10, 2):
        c = c + 1
    return c

# 5+4+3+2+1 == 15  (descending range with a negative literal step)
def descending_sum() -> int32:
    s: int32 = 0
    for i in range(5, 0, -1):
        s = s + i
    return s

# sum of the five elements == 10+20+30+40+5 == 105
def sum_array() -> int32:
    arr: Array[5, int32]
    arr[0] = 10
    arr[1] = 20
    arr[2] = 30
    arr[3] = 40
    arr[4] = 5
    total: int32 = 0
    for x in arr:
        total = total + x
    return total

# 0+1+2+3+4 == 10, then break before i==5
def with_break() -> int32:
    s: int32 = 0
    for i in range(100):
        if i == 5:
            break
        s = s + i
    return s

# odds only: 1+3+5+7+9 == 25; continue must still advance the counter
def with_continue() -> int32:
    s: int32 = 0
    for i in range(10):
        if i % 2 == 0:
            continue
        s = s + i
    return s

# 3*3 == 9 iterations of the inner body
def nested() -> int32:
    s: int32 = 0
    for i in range(3):
        for j in range(3):
            s = s + 1
    return s
