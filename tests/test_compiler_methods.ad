# Compiler regression: static methods + auto-self + name-mangled
# lowering (LANGUAGE.md "Static methods, auto-self, name mangling").
#
# Covers:
#   - Simple class with two methods, calls both
#   - Inheritance: child overrides one parent method, inherits another
#   - Multi-base inheritance: methods from each base resolve via
#     first-match-wins, with the right receiver_offset for non-zero
#     bases
#   - Pointer-vs-value receivers both work
#   - __init__ sugar (constructor)
#
# This is a HOST-SIDE test: the produced asm gets linked against
# scripts/test_compiler_methods_runner.c which calls __ad_main and
# encodes the result as the process exit code. The driver script
# verifies the expected exit code (so each scenario contributes its
# own digit to the result).


# ---- Scenario 1: simple class with two methods --------------------

class Foo:
    x: int32
    y: int32

    def sum(self) -> int32:
        return self.x + self.y

    def diff(self) -> int32:
        return self.x - self.y


# ---- Scenario 2: inheritance with override + inherit --------------

class Animal:
    legs: int32

    def kind(self) -> int32:
        return 1

    def num_legs(self) -> int32:
        return self.legs


class Dog(Animal):
    breed: int32

    def kind(self) -> int32:    # overrides Animal.kind
        return 2


# ---- Scenario 3: multi-base inheritance ---------------------------

class HasA:
    a: int32

    def get_a(self) -> int32:
        return self.a


class HasB:
    b: int32

    def get_b(self) -> int32:
        return self.b


class HasAB(HasA, HasB):
    c: int32


# ---- Scenario 4: pointer-receiver calls ---------------------------

def call_sum_through_ptr(p: Ptr[Foo]) -> int32:
    return p.sum()


# ---- Scenario 5: __init__ sugar -----------------------------------

class Point:
    x: int32
    y: int32

    def __init__(self, a: int32, b: int32) -> None:
        self.x = a
        self.y = b

    def dist_sq(self) -> int32:
        return self.x * self.x + self.y * self.y


# ---- Driver: pack each scenario's check into one return code ------
#
# Each scenario contributes 2 bits (max value 3). Five scenarios = 10
# bits total = max 1023. But Linux truncates `exit(rc)` to the low 8
# bits, so we collapse each scenario into ONE bit (0=fail, 1=pass) so
# the 5-scenario aggregate fits in 5 bits (max 31). The driver script
# checks exit code 31.

def __ad_main() -> int32:
    # Scenario 1: simple methods
    f: Foo
    f.x = 10
    f.y = 3
    s1: int32 = 0
    if f.sum() == 13:
        if f.diff() == 7:
            s1 = 1

    # Scenario 2: inheritance — override + inherit
    d: Dog
    d.legs  = 4
    d.breed = 7
    s2: int32 = 0
    if d.kind() == 2:           # Dog__kind override
        if d.num_legs() == 4:   # Animal__num_legs inherited
            s2 = 1

    # Scenario 3: multi-base — both bases' methods accessible
    ab: HasAB
    ab.a = 5
    ab.b = 11
    ab.c = 99
    s3: int32 = 0
    if ab.get_a() == 5:
        if ab.get_b() == 11:    # needs receiver_offset = sizeof(HasA)
            s3 = 1

    # Scenario 4: pointer receiver
    s4: int32 = 0
    if call_sum_through_ptr(&f) == 13:
        if f.sum() == 13:       # auto-& on value receiver still works
            s4 = 1

    # Scenario 5: __init__ sugar (both VarDecl-init and Assignment)
    p: Point = Point(3, 4)
    q: Point
    q = Point(5, 12)
    s5: int32 = 0
    if p.dist_sq() == 25:       # 9 + 16
        if q.dist_sq() == 169:  # 25 + 144
            s5 = 1

    # Pack: 1 bit per scenario.
    return s1 + s2 * 2 + s3 * 4 + s4 * 8 + s5 * 16
