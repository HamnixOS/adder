# tests/test_compiler_string_global.ad
#
# Compiler regression: a top-level global typed `Array[N, uint8]` may
# be initialised directly from a string literal.
#
# Before the fix, compiler/codegen_x86.py's gen_data() emit_init only
# accepted an IntLiteral initialiser; any other initialiser raised
#   "x86: global '<name>' must have an integer initializer"
# So a global string had to be materialised byte-by-byte at runtime
# (the `_init_*()` fill workaround seen across drivers/net/tls.ad,
# lib/x509/chain.ad, etc.). With the fix, the literal's bytes land in
# `.data` directly, NUL-padded out to the declared array length.
#
# This fixture exercises:
#   1. A string global shorter than its array (NUL padding path).
#   2. A string global whose length equals its array (no padding).
#   3. A string global containing an escape (\n) — the byte must be
#      a real 0x0A, not the two chars '\' 'n'.
#   4. Two adjacent string globals — proves the padding keeps each
#      symbol at exactly get_type_size() bytes so neither overruns
#      the other.
#
# Driven by scripts/test_compiler_string_global.sh: builds this as a
# userland ELF, plants it as /init, boots QEMU, greps the serial log
# for `[string_global] PASS`.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: int32)


# Case 1: shorter-than-array — bytes 0..3 are "abcd", 4..15 are NUL.
g_short: Array[16, uint8] = "abcd"

# Case 2: exact-fit — all 8 bytes used, no padding.
g_exact: Array[8, uint8] = "12345678"

# Case 3: escape — "ok\n" is 3 bytes, the 3rd being 0x0A.
g_escape: Array[8, uint8] = "ok\n"

# Case 4: an adjacent pair — g_first must not bleed into g_second.
g_first:  Array[8, uint8] = "AAAA"
g_second: Array[8, uint8] = "BBBB"


fail_msg: Array[24, uint8]
pass_msg: Array[24, uint8]


def emit_fail():
    fail_msg[0]  = 91   # '['
    fail_msg[1]  = 115  # 's'
    fail_msg[2]  = 116  # 't'
    fail_msg[3]  = 114  # 'r'
    fail_msg[4]  = 105  # 'i'
    fail_msg[5]  = 110  # 'n'
    fail_msg[6]  = 103  # 'g'
    fail_msg[7]  = 95   # '_'
    fail_msg[8]  = 103  # 'g'
    fail_msg[9]  = 108  # 'l'
    fail_msg[10] = 111  # 'o'
    fail_msg[11] = 98   # 'b'
    fail_msg[12] = 97   # 'a'
    fail_msg[13] = 108  # 'l'
    fail_msg[14] = 93   # ']'
    fail_msg[15] = 32   # ' '
    fail_msg[16] = 70   # 'F'
    fail_msg[17] = 65   # 'A'
    fail_msg[18] = 73   # 'I'
    fail_msg[19] = 76   # 'L'
    fail_msg[20] = 10   # '\n'
    sys_write(1, &fail_msg[0], 21)
    sys_exit(1)


def main():
    # Case 1: "abcd" then NUL padding.
    if g_short[0] != 97:
        emit_fail()
    if g_short[1] != 98:
        emit_fail()
    if g_short[2] != 99:
        emit_fail()
    if g_short[3] != 100:
        emit_fail()
    if g_short[4] != 0:
        emit_fail()
    if g_short[15] != 0:
        emit_fail()

    # Case 2: exact-fit "12345678".
    if g_exact[0] != 49:
        emit_fail()
    if g_exact[7] != 56:
        emit_fail()

    # Case 3: escape — third byte is a real newline (0x0A).
    if g_escape[0] != 111:        # 'o'
        emit_fail()
    if g_escape[1] != 107:        # 'k'
        emit_fail()
    if g_escape[2] != 10:         # '\n'
        emit_fail()
    if g_escape[3] != 0:          # padding
        emit_fail()

    # Case 4: adjacency — g_first holds "AAAA", g_second holds "BBBB",
    # and neither overran the other's storage.
    if g_first[0] != 65:
        emit_fail()
    if g_first[3] != 65:
        emit_fail()
    if g_first[4] != 0:
        emit_fail()
    if g_second[0] != 66:
        emit_fail()
    if g_second[3] != 66:
        emit_fail()
    if g_second[4] != 0:
        emit_fail()

    pass_msg[0]  = 91   # '['
    pass_msg[1]  = 115  # 's'
    pass_msg[2]  = 116  # 't'
    pass_msg[3]  = 114  # 'r'
    pass_msg[4]  = 105  # 'i'
    pass_msg[5]  = 110  # 'n'
    pass_msg[6]  = 103  # 'g'
    pass_msg[7]  = 95   # '_'
    pass_msg[8]  = 103  # 'g'
    pass_msg[9]  = 108  # 'l'
    pass_msg[10] = 111  # 'o'
    pass_msg[11] = 98   # 'b'
    pass_msg[12] = 97   # 'a'
    pass_msg[13] = 108  # 'l'
    pass_msg[14] = 93   # ']'
    pass_msg[15] = 32   # ' '
    pass_msg[16] = 80   # 'P'
    pass_msg[17] = 65   # 'A'
    pass_msg[18] = 83   # 'S'
    pass_msg[19] = 83   # 'S'
    pass_msg[20] = 10   # '\n'
    sys_write(1, &pass_msg[0], 21)
    sys_exit(0)
