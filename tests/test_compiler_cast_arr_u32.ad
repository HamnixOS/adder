# Compiler regression: cast[uint64](arr32[i]) where arr32 is
# Array[N, uint32] historically (per memory/feedback_compiler_quirks.md
# M16.97 note) returned a value whose upper 32 bits leaked stale bits,
# making `cast[uint64](arr32[i]) == want_u64` return false even when
# the low 32 bits matched the want's low 32.
#
# This fixture exists to PROVE the quirk: it loads through arr32[i]
# (which should `movl` zero-extend size=4 into a 64-bit reg), casts to
# uint64 (no-op at codegen, since all integers occupy a 64-bit slot),
# and compares. If the bug ever returns we get sys_exit != 0 + no
# PASS marker.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: int32)

arr32:    Array[4, uint32]
pass_msg: Array[24, uint8]


def main():
    rc: int32 = 0

    # Plant a value with the high bit of the low 32 bits set so that
    # if codegen ever did a sign-extending movslq the upper 32 bits
    # would become all-ones and the equality compare would FAIL.
    arr32[0] = 0xABCDEF12
    arr32[1] = 0xDEADBEEF
    arr32[2] = 0
    arr32[3] = 0xFFFFFFFF

    # Pattern 1: cast then read into a uint64 slot.
    v: uint64 = cast[uint64](arr32[0])
    if v != 0xABCDEF12:
        rc = 1

    # Pattern 2: cast-then-equal in one expression (this is the exact
    # shape arp_lookup hit when claimed-broken — must zero-extend).
    want: uint64 = 0xABCDEF12
    if rc == 0:
        if cast[uint64](arr32[0]) != want:
            rc = 2

    # Pattern 3: high-bit slot must still zero-extend, not sign-extend.
    if rc == 0:
        w2: uint64 = cast[uint64](arr32[3])
        if w2 != 0xFFFFFFFF:
            rc = 3

    # Pattern 4: iterate via a loop variable (mirrors arp_lookup's
    # `while i < N: arr_ip[i]`).
    if rc == 0:
        want1: uint64 = 0xDEADBEEF
        i: uint64 = 0
        found: int32 = 0
        while i < 4:
            if cast[uint64](arr32[i]) == want1:
                found = 1
            i = i + 1
        if found != 1:
            rc = 4

    if rc == 0:
        pass_msg[0]  = 91   # '['
        pass_msg[1]  = 99   # 'c'
        pass_msg[2]  = 111  # 'o'
        pass_msg[3]  = 109  # 'm'
        pass_msg[4]  = 112  # 'p'
        pass_msg[5]  = 95   # '_'
        pass_msg[6]  = 99   # 'c'
        pass_msg[7]  = 97   # 'a'
        pass_msg[8]  = 115  # 's'
        pass_msg[9]  = 116  # 't'
        pass_msg[10] = 51   # '3'
        pass_msg[11] = 50   # '2'
        pass_msg[12] = 93   # ']'
        pass_msg[13] = 32   # ' '
        pass_msg[14] = 80   # 'P'
        pass_msg[15] = 65   # 'A'
        pass_msg[16] = 83   # 'S'
        pass_msg[17] = 83   # 'S'
        pass_msg[18] = 10   # '\n'
        sys_write(1, &pass_msg[0], 19)
    sys_exit(rc)
